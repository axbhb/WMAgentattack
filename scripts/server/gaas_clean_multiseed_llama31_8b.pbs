#!/bin/bash
#PBS -N wma_clean_ms_8b
#PBS -q gpu_free
#PBS -l select=1:ncpus=4:ngpus=1
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

cd "$PBS_O_WORKDIR"

module load anaconda/2025
eval "$(/usr/local/anaconda2025/bin/conda shell.bash hook)"
conda activate "${ENV_NAME:-wmagentattack}"

export PYTHONPATH="$PBS_O_WORKDIR/src:$PBS_O_WORKDIR/external/agentdojo/src:${PYTHONPATH:-}"
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"
export HF_HUB_OFFLINE="${HF_HUB_OFFLINE:-1}"
export TRANSFORMERS_OFFLINE="${TRANSFORMERS_OFFLINE:-1}"
export TOKENIZERS_PARALLELISM=false

MODEL_PATH="${MODEL_PATH:-$HOME/.cache/huggingface/models--meta-llama--Meta-Llama-3.1-8B-Instruct/snapshots/0e9e39f249a16976918f6564b8830bc894c89659}"
MODEL_LABEL_BASE="${MODEL_LABEL_BASE:-meta-llama-3.1-8b-instruct-clean-ms}"
SEEDS="${SEEDS:-7}"
SUITES="${SUITES:-workspace}"
LOG_ROOT="${LOG_ROOT:-$PBS_O_WORKDIR/runs/agentdojo_clean_multiseed_llama31_8b_gaas}"
TEMPERATURE="${TEMPERATURE:-0.7}"
TOP_P="${TOP_P:-0.95}"

mkdir -p "$LOG_ROOT" artifacts

suite_args=()
for suite in $SUITES; do
  suite_args+=(--suite "$suite")
done

for seed in $SEEDS; do
  python scripts/10_run_agentdojo_hf_full.py \
    --model-path "$MODEL_PATH" \
    --model-label "${MODEL_LABEL_BASE}-seed${seed}" \
    --quantization 4bit \
    --protocol function_tags \
    --prompt-profile base \
    --max-input-tokens 8192 \
    --max-new-tokens 256 \
    --max-tool-output-chars 12000 \
    --agentdojo-local-alias \
    --clean-only \
    --force-rerun \
    --seed "$seed" \
    --do-sample \
    --temperature "$TEMPERATURE" \
    --top-p "$TOP_P" \
    --logdir "$LOG_ROOT/seed${seed}" \
    "${suite_args[@]}"
done

python scripts/20_summarize_clean_solvability.py \
  --clean-root "$LOG_ROOT" \
  --output artifacts/clean_multiseed_llama31_8b_solvability_gaas.json

