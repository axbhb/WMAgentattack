#!/bin/bash
#PBS -N wma_smoke
#PBS -q gpu_free
#PBS -l select=1:ncpus=4:ngpus=1
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

cd "$PBS_O_WORKDIR"

module load anaconda/2025
eval "$(/usr/local/anaconda2025/bin/conda shell.bash hook)"
conda activate "${ENV_NAME:-wmagentattack}"

export PYTHONPATH="$PBS_O_WORKDIR/src:$PBS_O_WORKDIR/external/agentdojo/src:${PYTHONPATH:-}"

hostname
nvidia-smi

python - <<'PY'
import importlib.util
import torch
from wmagentattack.schema import StepRecord

print("torch", torch.__version__)
print("cuda_available", torch.cuda.is_available())
if torch.cuda.is_available():
    print("gpu", torch.cuda.get_device_name(0))
print("agentdojo", bool(importlib.util.find_spec("agentdojo")))
print("sheeprl", bool(importlib.util.find_spec("sheeprl")))
print("schema", StepRecord.__name__)
PY

